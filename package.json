{
  "name": "behaviortree-viewer",
  "displayName": "BehaviorTree Viewer",
  "description": "Interactive visualizer and live monitor for BehaviorTree.CPP v4 XML files. Tree rendering, node search, blackboard inspector, node palette, drag layout, and real-time ZMQ status overlay.",
  "version": "0.1.1",
  "publisher": "NicholasJamesBell",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neoxra/vscode-bt-viewer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "preview": true,
  "categories": [
    "Visualization",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "behavior tree",
    "behaviortree",
    "BT.CPP",
    "robotics",
    "visualization",
    "xml"
  ],
  "activationEvents": [
    "onCommand:behaviortree.openViewer",
    "onLanguage:xml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "behaviortree.openViewer",
        "title": "Open Behavior Tree Viewer",
        "category": "BehaviorTree",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == xml",
          "command": "behaviortree.openViewer",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == xml",
          "command": "behaviortree.openViewer",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "behaviortree.openViewer",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "resourceExtname == .xml"
      }
    ],
    "configuration": {
      "title": "BehaviorTree Viewer",
      "properties": {
        "behaviortreeViewer.monitorHost": {
          "type": "string",
          "default": "localhost",
          "description": "Host for live BT.CPP ZMQ monitor connection"
        },
        "behaviortreeViewer.monitorPort": {
          "type": "number",
          "default": 1666,
          "description": "Port for live BT.CPP ZMQ monitor connection (REP socket; SUB is port+1)"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:zeromq --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0",
    "zeromq": "^6.5.0"
  }
}
